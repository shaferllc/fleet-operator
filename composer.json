{
    "name": "dply/fleet-operator",
    "description": "PHP middleware, config, and OpenAPI spec for Fleet Console operator APIs (GET …/summary and …/readme).",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/shaferllc/fleet-operator",
    "support": {
        "issues": "https://github.com/shaferllc/fleet-operator/issues",
        "source": "https://github.com/shaferllc/fleet-operator"
    },
    "replace": {
        "fleetphp/fleet-operator": "*"
    },
    "keywords": [
        "php",
        "fleet",
        "operator",
        "monitoring",
        "openapi",
        "middleware",
        "http"
    ],
    "authors": [
        {
            "name": "Fleet Console contributors"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.5.50|^12.5.8"
    },
    "autoload": {
        "psr-4": {
            "Dply\\FleetOperator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dply\\FleetOperator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dply\\FleetOperator\\FleetOperatorServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
